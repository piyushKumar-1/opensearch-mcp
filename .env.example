# Elasticsearch connection URL (e.g., https://my-cluster.es.us-east-1.aws.found.io:9243)
ELASTICSEARCH_URL=

# Base64-encoded Elasticsearch API key
ELASTICSEARCH_API_KEY=

# Server port (default 3000)
PORT=3000

# TLS certificate and key paths (optional -- omit for plain HTTP in dev)
TLS_CERT_PATH=
TLS_KEY_PATH=
